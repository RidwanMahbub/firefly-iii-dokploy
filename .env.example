# ============================================================
# FIREFLY III + DATA IMPORTER — COMBINED ENV FOR DOKPLOY
# ============================================================
# Paste all of these into the Dokploy Environment tab.
# Variables marked ← CHANGE THIS must be updated before deploying.
# ============================================================


# ------------------------------------------------------------
# APP (core)
# ------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_NAME=FireflyIII
FIREFLY_III_LAYOUT=v1

# Your external URL — must match the domain you set in Dokploy Domains tab
APP_URL=https://firefly.yourdomain.com          # ← CHANGE THIS

# Your email address (shown in some error pages)
SITE_OWNER=mail@example.com                     # ← CHANGE THIS

# Exactly 32 random characters — generate at:
# https://www.random.org/strings/?num=1&len=32&digits=on&upperalpha=on&loweralpha=on&unique=on&format=html&rnd=new
APP_KEY=SomeRandomStringOf32CharsExactly        # ← CHANGE THIS


# ------------------------------------------------------------
# DATABASE (shared by app + db containers)
# ------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=secret_firefly_password             # ← CHANGE THIS


# ------------------------------------------------------------
# CRON
# Exactly 32 random characters (same generator as APP_KEY)
# ------------------------------------------------------------
STATIC_CRON_TOKEN=PLEASE_REPLACE_WITH_32_CHAR_CODE  # ← CHANGE THIS


# ------------------------------------------------------------
# LOCALE & TIMEZONE
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# ------------------------------------------------------------
TZ=Europe/Amsterdam                             # ← CHANGE THIS
DEFAULT_LANGUAGE=en_US
DEFAULT_LOCALE=equal


# ------------------------------------------------------------
# PROXY — required for Dokploy/Traefik
# ------------------------------------------------------------
TRUSTED_PROXIES=**


# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
LOG_CHANNEL=stack
APP_LOG_LEVEL=notice
AUDIT_LOG_LEVEL=emergency
AUDIT_LOG_CHANNEL=


# ------------------------------------------------------------
# CACHE & SESSION
# ------------------------------------------------------------
CACHE_DRIVER=file
SESSION_DRIVER=file


# ------------------------------------------------------------
# MAIL (optional — default is disabled)
# See: https://docs.firefly-iii.org/how-to/firefly-iii/advanced/notifications/#email
# ------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=null
MAIL_PORT=2525
MAIL_FROM=changeme@example.com
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null


# ============================================================
# DATA IMPORTER
# ============================================================

# Internal URL the importer uses to talk to the app container — do NOT change this
FIREFLY_III_URL=http://app:8080

# Your public-facing Firefly III URL (same as APP_URL above)
VANITY_URL=https://firefly.yourdomain.com       # ← CHANGE THIS (same as APP_URL)

# Authentication — use ONE of the two options below:
#
# Option A (recommended): Personal Access Token
#   Generate at https://your-firefly-domain/profile → OAuth → Personal Access Tokens
FIREFLY_III_ACCESS_TOKEN=                       # ← CHANGE THIS (or use Client ID below)
#
# Option B: OAuth Client ID
#   Generate at https://your-firefly-domain/profile → OAuth → OAuth Clients
FIREFLY_III_CLIENT_ID=                          # ← CHANGE THIS (or use Access Token above)

# Importer log level (separate from the app log level)
IMPORTER_LOG_LEVEL=info

# Auto-import settings (leave empty/false to disable)
JSON_CONFIGURATION_DIR=
CAN_POST_AUTOIMPORT=false
CAN_POST_FILES=false
IMPORT_DIR_ALLOWLIST=
AUTO_IMPORT_SECRET=
