# === App ===
APP_ENV=production
APP_DEBUG=false
APP_NAME=FireflyIII
APP_KEY=SomeRandomStringOf32CharsExactly   # ← CHANGE THIS (exactly 32 chars)
APP_URL=https://your-domain.com            # ← CHANGE THIS

# === DB (shared by app + db service) ===
DB_CONNECTION=mysql
DB_PORT=3306
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=secret_firefly_password        # ← CHANGE THIS

# === Cron ===
STATIC_CRON_TOKEN=PLEASE_REPLACE_WITH_32_CHAR_CODE  # ← CHANGE THIS (exactly 32 chars)

# === Locale ===
TZ=Asia/Dhaka                              # ← your timezone
DEFAULT_LANGUAGE=en_US
DEFAULT_LOCALE=equal

# === Proxy / Security ===
TRUSTED_PROXIES=**

# === Misc ===
SITE_OWNER=mail@example.com               # ← CHANGE THIS
LOG_CHANNEL=stack
APP_LOG_LEVEL=notice
CACHE_DRIVER=file
SESSION_DRIVER=file

# === Mail (optional, log = disabled) ===
MAIL_MAILER=log
MAIL_HOST=null
MAIL_PORT=2525
MAIL_FROM=changeme@example.com
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null